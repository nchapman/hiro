# Hive Configuration
# Copy this file to .env and fill in your values.

# LLM Provider: "anthropic" or "openrouter"
HIRO_PROVIDER=anthropic

# API key for your chosen provider
HIRO_API_KEY=

# Model override (optional — defaults to model in agent.md)
# HIRO_MODEL=claude-sonnet-4-20250514

# Swarm code for worker authentication (auto-generated if not set)
# HIRO_SWARM_CODE=my-secret-code

# Listen address (default: :8120)
# HIRO_ADDR=:8120

# Path to agents directory (default: agents)
# HIRO_AGENTS_DIR=agents
