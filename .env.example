# Hive Configuration
# Copy this file to .env and fill in your values.

# LLM Provider: "anthropic" or "openrouter"
HIVE_PROVIDER=anthropic

# API key for your chosen provider
HIVE_API_KEY=

# Model override (optional — defaults to model in agent.md)
# HIVE_MODEL=claude-sonnet-4-20250514

# Swarm code for worker authentication (auto-generated if not set)
# HIVE_SWARM_CODE=my-secret-code

# Listen address (default: :8080)
# HIVE_ADDR=:8080

# Path to agents directory (default: agents)
# HIVE_AGENTS_DIR=agents
