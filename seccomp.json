    {
      "names": ["clone"],
      "action": "SCMP_ACT_ALLOW",
      "comment": "Allow clone with CLONE_NEWUSER (Docker default blocks it). Per-worker seccomp blocks clone(CLONE_NEWUSER) via BPF flag inspection and clone3 unconditionally."
    },
    {
      "names": ["clone3"],
      "action": "SCMP_ACT_ALLOW"
    },
    {
      "names": ["unshare"],
      "action": "SCMP_ACT_ALLOW",
